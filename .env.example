# Server-only Supabase credentials. Never prefix these with VITE_.
SUPABASE_URL=https://DEINE-ID.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service-role-key...

# Dashboard login. This is checked only in /api/login.
DASHBOARD_PASSWORD=DeinNeuesSicheresPasswort
DASHBOARD_SESSION_SECRET=SehrLangerZufaelligerSessionSecret

# Shopify webhook secret. Use a new long random value after redeploying.
SHOPIFY_WEBHOOK_SECRET=SehrLangerZufaelligerWebhookSecret

# Push notifications.
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_EMAIL=mailto:info@dofclothes.de

# Public browser value. This one is allowed to be visible in the built JS.
VITE_VAPID_PUBLIC_KEY=...

# Newsletter sending via Resend.
RESEND_API_KEY=re_...
NEWSLETTER_FROM=DOFClothes <support@dofclothes.de>
NEWSLETTER_REPLY_TO=support@dofclothes.de
NEWSLETTER_SECRET=SehrLangerZufaelligerNewsletterSecret
