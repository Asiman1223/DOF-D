# Supabase (aus Settings > API)
VITE_SUPABASE_URL=https://DEINE-ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon-key...

# Für den Shopify Webhook (Server-seitig, KEIN VITE_ Prefix!)
SUPABASE_URL=https://DEINE-ID.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service-role-key...

# Dashboard Passwort (frei wählbar)
VITE_DASHBOARD_PASSWORD=DeinPasswort123

# Shopify Webhook Secret (frei wählbar, z.B. ein langer zufälliger Text)
SHOPIFY_WEBHOOK_SECRET=mein-geheimes-passwort-fuer-shopify-2024
